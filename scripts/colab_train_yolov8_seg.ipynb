  "cells": [
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# YOLOv8n-seg Fine-Tuning for Mushroom Segmentation\n",
        "\n",
        "This notebook trains a YOLOv8n-seg model on SAM 2 generated mushroom masks.\n",
        "\n",
        "**Prerequisites:**\n",
        "- Upload `data/segmentation/` from your local project to Google Drive\n",
        "- Or use the direct-upload cell below"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Step 1: Install Dependencies"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "!pip install -q ultralytics\n",
        "import ultralytics\n",
        "print('Ultralytics version:', ultralytics.__version__)"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Step 2: Get the Dataset\n",
        "\n",
        "### Option A: Mount Google Drive (recommended)\n",
        "Upload your `data/segmentation/` folder to Drive first, then run:"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "from google.colab import drive\n",
        "drive.mount('/content/drive')\n",
        "\n",
        "# Adjust this path to where you uploaded data/segmentation/\n",
        "DATASET_YAML = '/content/drive/MyDrive/mushroom_segmentation/dataset.yaml'"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "### Option B: Direct Upload\n",
        "Run this cell and upload your zipped `data/segmentation/` folder:"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "from google.colab import files\n",
        "import zipfile\n",
        "import os\n",
        "\n",
        "uploaded = files.upload()\n",
        "zip_path = list(uploaded.keys())[0]\n",
        "\n",
        "with zipfile.ZipFile(zip_path, 'r') as z:\n",
        "    z.extractall('/content/dataset')\n",
        "\n",
        "# If you zipped the segmentation folder directly, use:\n",
        "# DATASET_YAML = '/content/dataset/dataset.yaml'\n",
        "# If you zipped the project root (data/segmentation/...), use:\n",
        "DATASET_YAML = '/content/dataset/data/segmentation/dataset.yaml'\n",
        "print('Extracted to:', DATASET_YAML)"}} 
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Step 3: Verify Dataset"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "import yaml\n",
        "from pathlib import Path\n",
        "\n",
        "with open(DATASET_YAML) as f:\n",
        "    cfg = yaml.safe_load(f)\n",
        "\n",
        "print('Dataset config:')\n",
        "for k, v in cfg.items():\n",
        "    print(f'  {k}: {v}')\n",
        "\n",
        "train_dir = Path(DATASET_YAML).parent / cfg['train']\n",
        "val_dir = Path(DATASET_YAML).parent / cfg['val']\n",
        "print(f'\\nTrain images: {len(list(train_dir.glob(\"*\")))}')\n",
        "print(f'Val images: {len(list(val_dir.glob(\"*\")))}')"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Step 4: Train YOLOv8n-seg\n",
        "\n",
        "Expected time on free T4 GPU: ~15–30 minutes"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "from ultralytics import YOLO\n",
        "\n",
        "model = YOLO('yolov8n-seg.pt')\n",
        "\n",
        "results = model.train(\n",
        "    data=DATASET_YAML,\n",
        "    epochs=100,\n",
        "    imgsz=640,\n",
        "    batch=8,\n",
        "    patience=20,\n",
        "    close_mosaic=10,\n",
        "    lr0=0.001,\n",
        "    project='yolov8_seg_runs',\n",
        "    name='mushroom_seg',\n",
        "    exist_ok=True,\n",
        "    device=0,\n",
        "    hsv_h=0.015,\n",
        "    hsv_s=0.7,\n",
        "    hsv_v=0.4,\n",
        ")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Step 5: Copy Best Checkpoint & Metadata"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "import shutil\n",
        "from pathlib import Path\n",
        "from datetime import datetime, timezone\n",
        "import json\n",
        "\n",
        "run_dir = Path('yolov8_seg_runs/mushroom_seg')\n",
        "best_pt = run_dir / 'weights' / 'best.pt'\n",
        "\n",
        "if not best_pt.exists():\n",
        "    best_pt = run_dir / 'weights' / 'last.pt'\n",
        "\n",
        "print('Best checkpoint:', best_pt)\n",
        "print('Checkpoint size:', f'{best_pt.stat().st_size / 1e6:.1f} MB')\n",
        "\n",
        "# Save to Colab files for download\n",
        "dest = Path('/content/yolov8_seg_ft.pt')\n",
        "shutil.copy(best_pt, dest)\n",
        "print('Copied to:', dest)\n",
        "\n",
        "# Metadata\n",
        "meta = {\n",
        "    'model': 'yolov8n-seg',\n",
        "    'training_date': datetime.now(timezone.utc).isoformat(),\n",
        "    'dataset_version': 'sam2-v1',\n",
        "    'epochs': 100,\n",
        "    'imgsz': 640,\n",
        "    'batch': 8,\n",
        "    'patience': 20,\n",
        "    'close_mosaic': 10,\n",
        "    'lr0': 0.001,\n",
        "    'class_map': {'0': 'mushroom'},\n",
        "    'source_checkpoint': 'yolov8n-seg.pt',\n",
        "}\n",
        "meta_path = Path('/content/yolov8_seg_ft_metadata.json')\n",
        "meta_path.write_text(json.dumps(meta, indent=2))\n",
        "print('Metadata:', meta_path)"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Step 6: Download to Local Machine\n",
        "\n",
        "Run this cell to download the fine-tuned model:"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "from google.colab import files\n",
        "files.download('/content/yolov8_seg_ft.pt')\n",
        "files.download('/content/yolov8_seg_ft_metadata.json')"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Step 7: Quick Validation\n",
        "\n",
        "Optional: run inference on a few val images to sanity-check the model"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "from ultralytics import YOLO\n",
        "import glob\n",
        "\n",
        "model = YOLO('/content/yolov8_seg_ft.pt')\n",
        "val_imgs = glob.glob(str(Path(DATASET_YAML).parent / 'images' / 'val' / '*'))[:3]\n",
        "\n",
        "for img in val_imgs:\n",
        "    results = model(img, verbose=False)\n",
        "    masks = results[0].masks\n",
        "    print(f'{Path(img).name}: {masks.data.shape[0] if masks is not None else 0} masks')"
      ]
    }
  ]
}
